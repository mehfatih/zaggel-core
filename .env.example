# zaggel-core environment (copy to .env; never commit .env)

# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database (Railway Postgres) ---
DATABASE_URL="postgresql://user:password@localhost:5432/zaggel?schema=public"

# --- Redis / BullMQ (events dispatcher; Railway add-on, Upstash fallback) ---
REDIS_URL="redis://localhost:6379"

# --- Auth (S1) ---
JWT_ACCESS_SECRET="change-me-long-random"
JWT_REFRESH_SECRET="change-me-different-long-random"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# --- Credentials vault (S1) — libsodium secret key, base64 (32 bytes) ---
# Generate once: node -e "import('libsodium-wrappers').then(async s=>{await s.default.ready;console.log(s.default.to_base64(s.default.randombytes_buf(32),s.default.base64_variants.ORIGINAL))})"
CREDENTIALS_VAULT_KEY=""

# --- API keys (S1) ---
API_KEY_PEPPER="change-me-api-pepper"

# --- Blacklist phone hashing (ADR-0004) ---
PHONE_HASH_PEPPER="change-me-to-a-long-random-string"

# --- Admin UI CORS allowlist (comma-separated origins) ---
ADMIN_CORS_ORIGINS="http://localhost:5173"

# --- WhatsApp (Meta Cloud API direct — A2). Populated in S4. ---
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""

# --- CDN (Cloudflare R2 for SDK; A3). Populated in S2/S7. ---
SDK_CDN_BASE_URL="https://cdn.zaggel.app/sdk"

# --- FX (reporting-only conversion; NEVER for display — A5). Optional. ---
FX_PROVIDER="manual"
FX_API_BASE_URL="https://api.exchangerate.host"
