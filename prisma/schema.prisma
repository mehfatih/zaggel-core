// Zaggel core — Prisma schema v1 (Sprint 0, Phase C).
// Multi-tenant: every tenant-scoped table carries org_id (directly or via parent),
// enforced by Prisma middleware (ADR-0001). Single Postgres DB.
//
// House rule: NO `prisma migrate deploy`. The committed raw SQL in
// prisma/migrations/0001_init.sql (IF NOT EXISTS) is applied manually via the
// Railway Data console; locally use `prisma db push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- enums -----------------------------

enum Plan {
  free
  pro
  agency
}

enum UserRole {
  owner
  staff
  agency
}

enum Platform {
  shopify
  woo
  salla
  zid
  custom
}

enum StoreStatus {
  active
  paused
  disconnected
}

enum PricingMode {
  linked
  independent
}

enum FormStatus {
  draft
  live
  paused
  archived
}

enum ProductSource {
  platform
  manual
}

enum NumeralStyle {
  western // 21,000
  arabic // ٢١٬٠٠٠ (Arabic-Indic)
}

enum SymbolPosition {
  before
  after
}

enum OrderStatus {
  submitted
  wa_confirmed
  shipped
  delivered
  refused
  cancelled
}

enum EventPlatform {
  meta
  tiktok
  snap
}

enum OutboxStatus {
  pending
  sent
  failed
}

enum BlacklistReason {
  refused
  troll
  fraud
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

enum SubscriptionSource {
  shopify
  salla
  zid
  woo
  manual
}

enum WaTemplateStatus {
  draft
  submitted
  approved
  rejected
  paused
}

// ----------------------------- tenancy roots -----------------------------

model Org {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(free)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  stores           Store[]
  blacklistOrigin  BlacklistEntry[] @relation("BlacklistSourceOrg")
  subscriptions    Subscription[]
  usageCounters    UsageCounter[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  reportingRates   ReportingRate[]
  waSettings       WaSettings?
  waTemplates      WaTemplate[]
  webhookEndpoints WebhookEndpoint[]
  adDestinations   AdDestination[]
  adCosts          AdCost[]

  @@map("orgs")
}

model User {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  email        String   @unique
  passwordHash String?  @map("password_hash") // null for platform-session users (S7)
  role         UserRole @default(owner)
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([orgId])
  @@map("users")
}

model Store {
  id              String      @id @default(cuid())
  orgId           String      @map("org_id")
  platform        Platform
  domain          String
  credentialsJson Json?       @map("credentials_json") // libsodium sealed box (ADR/S1 vault)
  status          StoreStatus @default(active)
  verificationToken  String?   @map("verification_token")
  verificationMethod String?   @map("verification_method") // dns_txt | meta_tag
  verifiedAt         DateTime? @map("verified_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  org            Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  forms          Form[]
  products       Product[]
  orders         Order[]
  abandonedLeads AbandonedLead[]

  @@index([orgId])
  @@map("stores")
}

model Form {
  id          String      @id @default(cuid())
  storeId     String      @map("store_id")
  name        String
  schemaJson  Json?       @map("schema_json")
  designJson  Json?       @map("design_json")
  pricingJson Json?       @map("pricing_json") // form-level pricing settings (S3): display currency, numeral override, free-ship threshold, Mode-A display rate
  pricingMode PricingMode @default(independent) @map("pricing_mode")
  status      FormStatus  @default(draft)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  formProducts   FormProduct[]
  shippingRules  ShippingRule[]
  orders         Order[]
  abandonedLeads AbandonedLead[]

  @@index([storeId])
  @@map("forms")
}

model Product {
  id          String        @id @default(cuid())
  storeId     String        @map("store_id")
  externalId  String?       @map("external_id")
  title       String
  imageUrl    String?       @map("image_url")
  linkedPrice Decimal?      @map("linked_price") @db.Decimal(18, 3)
  source      ProductSource @default(manual)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  formProducts FormProduct[]

  @@index([storeId])
  @@map("products")
}

// Per-form pricing override for a product (Mode B — independent pricing, S3).
model FormProduct {
  id                 String   @id @default(cuid())
  formId             String   @map("form_id")
  productId          String   @map("product_id")
  independentPrice   Decimal? @map("independent_price") @db.Decimal(18, 3)
  independentCurrency String?  @map("independent_currency")
  compareAtPrice     Decimal? @map("compare_at_price") @db.Decimal(18, 3)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  form     Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  currency Currency? @relation(fields: [independentCurrency], references: [code])

  @@unique([formId, productId])
  @@index([formId]) // approved addition #2
  @@map("form_products")
}

// ----------------------------- seeded catalogs (global, not tenant-scoped) -----------------------------

model Currency {
  code      String         @id // ISO 4217, e.g. IQD, SAR, TRY
  symbolAr  String         @map("symbol_ar")
  symbolEn  String         @map("symbol_en")
  nameAr    String         @map("name_ar")
  nameEn    String         @map("name_en")
  decimals  Int            @default(2)
  numeralStyle NumeralStyle @default(western) @map("numeral_style")
  position  SymbolPosition @default(after)

  formProducts       FormProduct[]
  shippingRules      ShippingRule[]
  reportingRatesFrom ReportingRate[] @relation("RateFrom")
  reportingRatesTo   ReportingRate[] @relation("RateTo")

  @@map("currencies")
}

// Merchant-set, DATED FX rates for REPORTING conversion only (S3, scope §3).
// NEVER applied to displayed prices (L4) — display is always the authored pair.
// Reporting/analytics dashboards consume this in S5; S3 ships the table + helper.
model ReportingRate {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  rate         Decimal  @db.Decimal(18, 8) // 1 fromCurrency = rate × toCurrency
  effectiveOn  DateTime @map("effective_on") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org  Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  from Currency @relation("RateFrom", fields: [fromCurrency], references: [code])
  to   Currency @relation("RateTo", fields: [toCurrency], references: [code])

  @@unique([orgId, fromCurrency, toCurrency, effectiveOn])
  @@index([orgId])
  @@map("reporting_rates")
}

model Governorate {
  id          String   @id @default(cuid())
  countryCode String   @map("country_code") // ISO 3166-1 alpha-2
  iso3166_2   String?  @map("iso_3166_2") // ISO 3166-2 subdivision code
  nameAr      String   @map("name_ar")
  nameEn      String   @map("name_en")
  sort        Int      @default(0)

  shippingRules ShippingRule[]
  orders        Order[]

  @@unique([countryCode, iso3166_2])
  @@index([countryCode])
  @@map("governorates")
}

model ShippingRule {
  id            String   @id @default(cuid())
  formId        String   @map("form_id")
  governorateId String   @map("governorate_id")
  fee           Decimal  @db.Decimal(18, 3)
  currency      String
  etaText       String?  @map("eta_text")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  form        Form        @relation(fields: [formId], references: [id], onDelete: Cascade)
  governorate Governorate @relation(fields: [governorateId], references: [id])
  currencyRef Currency    @relation(fields: [currency], references: [code])

  @@unique([formId, governorateId])
  @@index([formId])
  @@map("shipping_rules")
}

// ----------------------------- orders & downstream -----------------------------

model Order {
  id            String      @id @default(cuid())
  formId        String      @map("form_id")
  storeId       String      @map("store_id")
  status        OrderStatus @default(submitted)

  customerName String  @map("customer_name")
  phoneE164    String  @map("phone_e164")
  governorateId String? @map("governorate_id")
  addressText  String? @map("address_text")
  landmarkText String? @map("landmark_text")

  itemsJson Json @map("items_json")

  // Accounting integrity (S3): what the customer SAW vs the store mapping.
  displayPrice    Decimal  @map("display_price") @db.Decimal(18, 3)
  displayCurrency String   @map("display_currency")
  storePrice      Decimal? @map("store_price") @db.Decimal(18, 3)
  storeCurrency   String?  @map("store_currency")

  // Attribution (consumed in S5).
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")
  clickIdFbc  String? @map("click_id_fbc")
  clickIdTtclid String? @map("click_id_ttclid")
  fbp         String? @map("fbp") // Meta browser id (_fbp cookie) — advanced matching / EMQ (S5)
  ip          String?
  userAgent   String? @map("user_agent")

  riskScore         Int      @default(0) @map("risk_score")
  statusHistoryJson Json?    @map("status_history_json")

  // S4: staff assignment (confirmation teams / agency mode foundation) and the
  // `unreachable` substate retry counter (NOT a canonical ladder rung — ADR-0003).
  assignedTo       String? @map("assigned_to")
  unreachableCount Int     @default(0) @map("unreachable_count")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  form           Form            @relation(fields: [formId], references: [id])
  store          Store           @relation(fields: [storeId], references: [id])
  governorate    Governorate?    @relation(fields: [governorateId], references: [id])
  events         EventOutbox[]
  waConversation WaConversation?
  abandonedLeads AbandonedLead[]

  @@index([formId, status]) // approved addition #2
  @@index([phoneE164]) // approved addition #2
  @@index([storeId])
  @@map("orders")
}

model EventOutbox {
  id             String        @id @default(cuid())
  orderId        String        @map("order_id")
  platform       EventPlatform
  eventName      String        @map("event_name")
  payloadJson    Json          @map("payload_json")
  status         OutboxStatus  @default(pending)
  attempts       Int           @default(0)
  lastError      String?       @map("last_error") // S5: dispatcher failure diagnostics (dead-letter view)
  nextAttemptAt  DateTime?     @map("next_attempt_at") // S5: backoff schedule for retries
  idempotencyKey String        @unique @map("idempotency_key") // approved addition #1 (ADR-0005)
  sentAt         DateTime?     @map("sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([orderId])
  @@map("events_outbox")
}

// Per-platform ad destination (S5, ADR-0012): where the event ladder is sent.
// One row per (org, store, platform); store_id NULL = org-wide default, a store
// row overrides it (multi-brand orgs run different pixels/ad accounts). The access
// token is sealed via the libsodium vault (same posture as wa_settings).
//
// Uniqueness is enforced by TWO PARTIAL unique indexes in raw SQL (Prisma can't
// express a WHERE-filtered unique): one for store-specific rows, one for org-wide
// rows. See prisma/migrations/0005_s5_ad_signal.sql.
model AdDestination {
  id              String        @id @default(cuid())
  orgId           String        @map("org_id")
  storeId         String?       @map("store_id") // null = org-wide default
  platform        EventPlatform
  pixelId         String        @map("pixel_id") // pixel / dataset id
  credentialsJson Json?         @map("credentials_json") // sealed box: { accessToken }
  testEventCode   String?       @map("test_event_code") // Meta Test Events code
  reportingCurrency String?     @map("reporting_currency") // ad-account currency: target for unsupported display currencies (ADR-0009)
  purchaseRung    OrderStatus   @default(wa_confirmed) @map("purchase_rung") // L6: rung mapped to Purchase
  submittedEvent  String        @default("Lead") @map("submitted_event") // Lead | AddPaymentInfo (STOP-1)
  enabled         Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("ad_destinations")
}

// Manual ad-spend import (S5, CSV v1) → feeds delivered-ROAS in the attribution
// dashboard. Keyed by utm campaign/content/term (the Levana naming convention).
// Marketing-API auto-ingestion is backlog (out of scope per S5).
model AdCost {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  spendOn     DateTime @map("spend_on") @db.Date
  utmCampaign String?  @map("utm_campaign")
  utmContent  String?  @map("utm_content")
  utmTerm     String?  @map("utm_term")
  amount      Decimal  @db.Decimal(18, 3)
  currency    String
  createdAt   DateTime @default(now()) @map("created_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("ad_costs")
}

// Cross-org by design (hashed, contribute-to-consume — ADR-0004 / L7). Not org-scoped on read.
model BlacklistEntry {
  id          String          @id @default(cuid())
  phoneHash   String          @map("phone_hash") // SHA-256(E.164 + pepper)
  reason      BlacklistReason
  sourceOrgId String          @map("source_org_id")
  confidence  Int             @default(1)
  createdAt   DateTime        @default(now()) @map("created_at")

  sourceOrg Org @relation("BlacklistSourceOrg", fields: [sourceOrgId], references: [id], onDelete: Cascade)

  @@index([phoneHash]) // approved addition #2
  @@map("blacklist_entries")
}

model WaConversation {
  id            String    @id @default(cuid())
  orderId       String    @unique @map("order_id")
  waId          String    @map("wa_id")
  state         String
  humanHandoff  Boolean   @default(false) @map("human_handoff") // kill-switch: stops all automation on the thread
  optedOut      Boolean   @default(false) @map("opted_out") // buyer sent إيقاف
  lastMessageAt DateTime? @map("last_message_at")
  lastInboundAt DateTime? @map("last_inbound_at") // anchors the 24h customer-service window
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  messages WaMessage[]

  @@map("wa_conversations")
}

// Inbound/outbound WA message log. `providerMessageId` is UNIQUE so the inbound
// webhook is idempotent on replay (S4 testing bar).
model WaMessage {
  id                String   @id @default(cuid())
  conversationId    String   @map("conversation_id")
  direction         String // inbound | outbound
  providerMessageId String?  @unique @map("provider_message_id")
  type              String // template | text | button | system
  bodyJson          Json     @map("body_json")
  createdAt         DateTime @default(now()) @map("created_at")

  conversation WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("wa_messages")
}

// Per-org WhatsApp settings. The access token is sealed via the libsodium vault
// (same posture as stores.credentials_json). One row per org.
model WaSettings {
  id                   String   @id @default(cuid())
  orgId                String   @unique @map("org_id")
  phoneNumberId        String?  @map("phone_number_id")
  wabaId               String?  @map("waba_id")
  credentialsJson      Json?    @map("credentials_json") // sealed box: { accessToken }
  autoAdvance          Boolean  @default(false) @map("auto_advance") // confirm reply → wa_confirmed without manual review
  recoveryEnabled      Boolean  @default(true) @map("recovery_enabled")
  recoveryDelayMinutes Int      @default(30) @map("recovery_delay_minutes")
  recoveryFrequencyCap Int      @default(1) @map("recovery_frequency_cap")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("wa_settings")
}

// WA message templates with Meta approval tracking (template manager, scope §2).
model WaTemplate {
  id                 String           @id @default(cuid())
  orgId              String           @map("org_id")
  name               String // order_confirm | order_confirmed_thanks | abandoned_recovery | shipped_update | otp
  language           String           @default("ar")
  category           String // utility | marketing | authentication
  bodyText           String           @map("body_text")
  variablesJson      Json?            @map("variables_json")
  status             WaTemplateStatus @default(draft)
  providerTemplateId String?          @map("provider_template_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name, language])
  @@index([orgId])
  @@map("wa_templates")
}

// Phone captured before submit (SDK `zaggel:start`, scope §2). Recovered when a
// matching order arrives or the recovery template is sent.
model AbandonedLead {
  id        String   @id @default(cuid())
  formId    String   @map("form_id")
  storeId   String   @map("store_id")
  phoneE164 String   @map("phone_e164")
  sendAfter DateTime @map("send_after")
  recovered Boolean  @default(false)
  attempts  Int      @default(0)
  orderId   String?  @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  form  Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
  store Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@index([sendAfter])
  @@index([storeId])
  @@map("abandoned_leads")
}

// Outbound webhook subscriptions (signed payloads — D14 groundwork, scope §3).
model WebhookEndpoint {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  url        String
  secret     String // HMAC signing secret
  eventsJson Json     @map("events_json") // ["order.created","order.confirmed","order.delivered","order.refused"]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org        Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([orgId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String       @id @default(cuid())
  endpointId     String       @map("endpoint_id")
  eventName      String       @map("event_name")
  payloadJson    Json         @map("payload_json")
  status         OutboxStatus @default(pending)
  attempts       Int          @default(0)
  idempotencyKey String       @unique @map("idempotency_key")
  deliveredAt    DateTime?    @map("delivered_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([endpointId])
  @@map("webhook_deliveries")
}

// ----------------------------- entitlements (S1) -----------------------------

// Plan catalog — seeded from the PLAN_MATRIX single source of truth.
// Global (not org-scoped); `code` is the join key used by subscriptions.
model PricingPlan {
  code         String   @id // free | growth | pro | agency
  name         String
  featuresJson Json     @map("features_json")
  limitsJson   Json     @map("limits_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String             @id @default(cuid())
  orgId            String             @map("org_id")
  planCode         String             @map("plan_code")
  status           SubscriptionStatus @default(active)
  source           SubscriptionSource @default(manual)
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  org  Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan PricingPlan @relation(fields: [planCode], references: [code])

  @@index([orgId])
  @@map("subscriptions")
}

model UsageCounter {
  id     String @id @default(cuid())
  orgId  String @map("org_id")
  metric String // e.g. orders_submitted | wa_confirmed
  period String // YYYY-MM
  count  Int    @default(0)

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, metric, period])
  @@index([orgId])
  @@map("usage_counters")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") // sha-256 of the refresh token
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String    @id @default(cuid())
  orgId      String    @map("org_id")
  name       String
  prefix     String // first chars, shown in UI
  keyHash    String    @map("key_hash") // sha-256(key + pepper)
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([keyHash])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metaJson   Json?    @map("meta_json")
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("audit_logs")
}
